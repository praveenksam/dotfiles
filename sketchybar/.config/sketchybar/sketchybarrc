#!/bin/bash
export CONFIG_DIR="/Users/praveensam/.config/sketchybar"
source "$CONFIG_DIR/colors.sh"

# Bar appearance
sketchybar --bar \
  height=40 \
  position=top \
  sticky=on \
  padding_left=10 \
  padding_right=10 \
  color=$BAR_COLOR \
  blur_radius=50 \
  corner_radius=0 \
  shadow=off

# Defaults
sketchybar --default \
  icon.font="JetBrainsMono Nerd Font Mono:Bold:14.0" \
  label.font="JetBrainsMono Nerd Font Mono:Regular:13.0" \
  icon.color=$WHITE \
  label.color=$WHITE \
  padding_left=6 \
  padding_right=6 \
  label.padding_left=4 \
  label.padding_right=4 \
  icon.padding_left=4 \
  icon.padding_right=4

# Left: Aerospace workspaces
sketchybar --add event aerospace_workspace_change

for sid in 1 2 3 4 5 6 B P S; do
  sketchybar --add item space.$sid left \
    --set space.$sid \
    icon="$sid" \
    icon.font="JetBrainsMono Nerd Font Mono:Bold:12.0" \
    label.font="sketchybar-app-font:Regular:14.0" \
    background.color=$SURFACE0 \
    background.corner_radius=6 \
    background.height=26 \
    background.padding_left=4 \
    background.padding_right=4 \
    label.drawing=off
done

# Single subscriber that updates all workspaces
sketchybar --add item workspace_tracker left \
  --set workspace_tracker \
  drawing=off \
  script="$CONFIG_DIR/plugins/workspace.sh" \
  --subscribe workspace_tracker aerospace_workspace_change

# Right: Clock, Battery, WiFi, CPU (added right to left)
sketchybar --add item padding right \
  --set padding \
  width=10 \
  drawing=on \
  label.drawing=off \
  icon.drawing=off

sketchybar --add item clock right \
  --set clock \
  update_freq=10 \
  icon= \
  icon.color=$BLUE \
  script="$CONFIG_DIR/plugins/clock.sh"

sketchybar --add item battery right \
  --set battery \
  update_freq=60 \
  script="$CONFIG_DIR/plugins/battery.sh" \
  --subscribe battery power_source_change

sketchybar --add item wifi right \
  --set wifi \
  update_freq=30 \
  icon=󰤨 \
  icon.color=$TEAL \
  script="$CONFIG_DIR/plugins/wifi.sh"

sketchybar --add item memory right \
  --set memory \
  update_freq=5 \
  icon= \
  icon.color=$RED \
  script="$CONFIG_DIR/plugins/memory.sh"

sketchybar --add item cpu right \
  --set cpu \
  update_freq=5 \
  icon= \
  icon.color=$MAGENTA \
  script="$CONFIG_DIR/plugins/cpu.sh"

sketchybar --update

# Force initial run of all scripts
FOCUSED_WORKSPACE=$(aerospace list-workspaces --focused) $CONFIG_DIR/plugins/workspace.sh
$CONFIG_DIR/plugins/clock.sh
$CONFIG_DIR/plugins/cpu.sh
$CONFIG_DIR/plugins/memory.sh
$CONFIG_DIR/plugins/wifi.sh
$CONFIG_DIR/plugins/battery.sh
